# Keep folder structure but ignore all files inside INPUT/BOM and OUTPUT/BOM
INPUT/BOM/*
!INPUT/BOM/.gitkeep

OUTPUT/BOM/*
!OUTPUT/BOM/.gitkeep

# Keep folder structure but ignore all files inside INPUT/SCH and OUTPUT/SCH
INPUT/SCH/*
!INPUT/SCH/.gitkeep

OUTPUT/SCH/*
!OUTPUT/SCH/.gitkeep

# Keep folder structure but ignore all files inside INPUT/ALTERNATIVE and OUTPUT/ALTERNATIVE
INPUT/ALTERNATIVE/*
!INPUT/ALTERNATIVE/.gitkeep

OUTPUT/ALTERNATIVE/*
!OUTPUT/ALTERNATIVE/.gitkeep

# Keep folder structure but ignore all files inside INPUT/SYMBOL and OUTPUT/SYMBOL
INPUT/SYMBOL/*
!INPUT/SYMBOL/.gitkeep

OUTPUT/SYMBOL/*
!OUTPUT/SYMBOL/.gitkeep

# Eval / iteration workspaces created by the skill-creator
.claude/skills/*-workspace/

# Dependencies
node_modules/

# Python
__pycache__/
*.pyc
*.pyo

# OS files
.DS_Store
Thumbs.db
